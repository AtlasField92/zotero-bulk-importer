# ============================================================
# Dockerfile: Static Build + Nginx Server
# Usage: docker build -f Dockerfile.static -t mysite:static .
# ============================================================

# -------------------------------------------------
# Stage 1: BUILDER — generates the static site
# -------------------------------------------------
FROM node:20-alpine AS builder

WORKDIR /app

# 1. Copy dependency files for the layer cache
COPY package*.json ./

# 2. Install dependencies
RUN npm install

# 3. Copy source code
COPY . .

# 4. Build in static mode (prerender SPA)
#    Uses the dedicated vite.config.static.ts config which directly uses
#    the @tanstack/react-start/plugin/vite plugin (avoids a mismatch
#    on the server filename with @lovable.dev/vite-tanstack-config).
RUN npx vite build --config vite.config.static.ts

# 5. Rename the prerendered shell to index.html for the static server
RUN mv dist/client/_shell.html dist/client/index.html

# -------------------------------------------------
# Stage 2: RUNTIME — nginx server for static files
# -------------------------------------------------
FROM nginx:alpine

# Copy built assets from builder stage
COPY --from=builder /app/dist/client /usr/share/nginx/html

# Nginx configuration: fallback SPA (all routes → index.html)
RUN echo 'server { \
    listen 80; \
    server_name localhost; \
    root /usr/share/nginx/html; \
    index index.html; \
    location / { \
        try_files $uri $uri/ /index.html; \
    } \
    # Cache Vite-versioned assets \
    location /assets/ { \
        expires 1y; \
        add_header Cache-Control "public, immutable"; \
    } \
    # Public static files \
    location = /robots.txt  { access_log off; log_not_found off; } \
    location = /sitemap.xml { access_log off; log_not_found off; } \
    location = /llms.txt    { access_log off; log_not_found off; } \
}' > /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
